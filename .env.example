# Put these in `.env` (typical) or `.env.local` (optional local overrides).
# Both are gitignored. EAS: set the same vars as Secrets for production builds.
# Values: Supabase Dashboard → Project Settings → API.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_AUTH_HOSTNAME.example.com

# Publishable key (Dashboard → Project Settings → API)
EXPO_PUBLIC_SUPABASE_KEY=your_publishable_key

# Crash reporting — Sentry (optional; disabled silently when unset).
# Get a DSN at https://sentry.io → Project → Settings → Client Keys.
# Set as an EAS Secret for production builds.
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# RevenueCat (in-app subscriptions). Required when src/lib/payments.ts has
# PAYMENTS_ENABLED = true. Get keys from https://app.revenuecat.com →
# Project Settings → API Keys.
#   - Test mode: a single shared key starting with test_ works for both
#     platforms; set EXPO_PUBLIC_REVENUECAT_API_KEY.
#   - Production: use platform-specific keys (appl_ and goog_).
EXPO_PUBLIC_REVENUECAT_API_KEY=test_xxx
# EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxx
# EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxx
