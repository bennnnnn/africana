# Expo SDK 54 ships with react@19.1.0, but several optional/transitive packages
# (react-dom, some @radix-ui sub-packages) declare a stricter peer of
# react@^19.2.5. We don't actually use those packages on the mobile target —
# they're brought in by `@expo/metro-runtime`'s web entry — so the conflict is
# cosmetic. Telling npm (both locally and on EAS Build's remote runner) to
# fall back to the legacy resolver lets installs go through cleanly.
#
# Without this, `eas build` fails in its "Install dependencies" phase even
# though the same install works locally with --legacy-peer-deps.
legacy-peer-deps=true
