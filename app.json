{
  "expo": {
    "name": "Africana",
    "slug": "africana",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "africana",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E9F6E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.africana.dating",
      "runtimeVersion": "1.0.0",
      "associatedDomains": [
        "applinks:joinafricana.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E9F6E"
      },
      "package": "com.africana.dating",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [],
      "runtimeVersion": "1.0.0",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "joinafricana.com",
              "pathPrefix": "/profile-share.html"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Africana needs access to your photos to set a profile picture.",
          "cameraPermission": "Africana needs camera access to take a profile photo."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0E9F6E",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0E9F6E"
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "56908a4f-a73b-4237-b925-7b3e00446e53"
      }
    },
    "owner": "abebech",
    "updates": {
      "url": "https://u.expo.dev/56908a4f-a73b-4237-b925-7b3e00446e53"
    }
  }
}
